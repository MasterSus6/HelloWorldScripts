function HW.Players.GetStats(player)
    ingameplayers = ingameplayers or workspace:FindFirstChild("InGamePlayers")
    
    local plr = ingameplayers and ingameplayers:FindFirstChild(player.Name)
    return plr and plr:FindFirstChild("Stats")
end

function HW.Players.GetHealth(player)
    local stats = HW.Players.GetStats(player)
    return stats and stats.Health.Value or 0
end

function HW.Players.IsAlive(player)
    return HW.Players.GetHealth(player) > 0
end

function HW.Players.GetAlive()
    local t = {}
    
    for _, plr in pairs(Players:GetPlayers()) do
        if HW.Players.IsAlive(plr) then
            table.insert(t, plr)
        end
    end
    
    return t
end

function HW.Players.GetStamina(player)
    local folder = ingameplayers:FindFirstChild(player.Name)
    return folder and folder.Stats.CurrentStamina.Value or 0
end

function HW.Players.GetMaxStamina(player)
    local folder = ingameplayers:FindFirstChild(player.Name)
    return folder and folder.Stats.Stamina.Value or 100
end

function HW.Players.GetInventory(player)
    local folder = ingameplayers:FindFirstChild(player.Name)
    if not folder then return {} end
    
    local inv = folder:FindFirstChild("Inventory")
    if not inv then return {} end
    
    return {
        inv.Slot1.Value,
        inv.Slot2.Value,
        inv.Slot3.Value
    }
end

function HW.Players.IsDecoding(player)
    local folder = ingameplayers:FindFirstChild(player.Name)
    return folder and folder.Decoding.Value ~= nil
end

