function HW.Twisteds.GetAll()
    local map = Utils.GetMap()
    if not map then return {} end
    
    local monsters = map:FindFirstChild("Monsters")
    return monsters and monsters:GetChildren() or {}
end

function HW.Twisteds.GetNearest()
    local char = LocalPlayer.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local closest, dist = nil, math.huge
    
    for _, t in pairs(HW.Twisteds.GetAll()) do
        local d = Utils.GetDistance(root, t)
        if d < dist then
            closest = t
            dist = d
        end
    end
    
    return closest
end

function HW.Twisteds.GetNearestDistance()
    local nearest = HW.Twisteds.GetNearest()
    local char = LocalPlayer.Character
    if not (nearest and char) then return math.huge end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    return Utils.GetDistance(root, nearest)
end

