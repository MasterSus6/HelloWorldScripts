--// ========================
--// MACHINES
--// ========================

function HW.Machines.GetCompleted()
    return info.GeneratorsCompleted.Value or 0
end

function HW.Machines.GetTotal()
    return info.RequiredGenerators.Value or 0
end

function HW.Machines.GetRemaining()
    return HW.Machines.GetTotal() - HW.Machines.GetCompleted()
end

function HW.Machines.IsLast()
    return HW.Machines.GetRemaining() == 1
end

function HW.Machines.GetProgressDecimal()
    local total = HW.Machines.GetTotal()
    if total == 0 then return 0 end
    
    return HW.Machines.GetCompleted() / total
end

function HW.Machines.GetProgressPercent()
    return HW.Machines.GetProgressDecimal() * 100
end

function HW.Machines.GetAll()
    local map = Utils.GetMap()
    if not map then return {} end
    
    local gens = map:FindFirstChild("Generators")
    return gens and gens:GetChildren() or {}
end

function HW.Machines.GetNearest()
    local char = LocalPlayer.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local closest, dist = nil, math.huge
    
    for _, gen in pairs(HW.Machines.GetAll()) do
        local d = Utils.GetDistance(root, gen)
        if d < dist then
            closest = gen
            dist = d
        end
    end
    
    return closest
end

function HW.Machines.IsCompleted(machine)
    local stats = machine:FindFirstChild("Stats")
    return stats and stats.Completed.Value or false
end

function HW.Machines.GetProgress(machine)
    local stats = machine:FindFirstChild("Stats")
    
    if not stats then return 0 end
    
    local current = stats.CurrentAmount.Value
    local required = stats.RequiredAmount.Value
    
    if required == 0 then return 0 end
    
    return current / required
end

