function HW.Events.OnGameStarted(callback)
    local conn = info.GameStarted:GetPropertyChangedSignal("Value"):Connect(function()
        if info.GameStarted.Value then
            callback()
        end
    end)
    connections[conn] = true
    return conn
end

function HW.Events.OnMachineCompleted(callback)
    local conn = info.GeneratorsCompleted:GetPropertyChangedSignal("Value"):Connect(function()
        callback(info.GeneratorsCompleted.Value)
    end)
    connections[conn] = true
    return conn
end

