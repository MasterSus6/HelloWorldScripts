function Utils.IsValid(obj)
    return obj and obj.Parent ~= nil
end

function Utils.GetPosition(obj)
    if not obj then return nil end

    if obj:IsA("BasePart") then
        return obj.Position
    end

    if obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.Position
        end

        local pivot = obj:GetPivot()
        if pivot then
            return pivot.Position
        end

        -- fallback: tenta pegar qualquer part
        local part = obj:FindFirstChildWhichIsA("BasePart")
        if part then
            return part.Position
        end
    end

    return nil
end

function Utils.GetDistance(a, b)
    local posA = Utils.GetPosition(a)
    local posB = Utils.GetPosition(b)

    if not posA or not posB then
        return math.huge
    end

    return (posA - posB).Magnitude
end

