end

function HW.Game.IsBlackout()
    return info.BlackOut.Value or false
end

function HW.Game.IsPanic()
    return info.Panic.Value or false
end

function HW.Game.IsHurryUp()
    return info.HurryUp.Value or false
end

function HW.Game.GetGameState()
    if info.Voting.Value then
        return "Voting"
    elseif info.FloorActive.Value then
        return "ActiveFloor"
