local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/riddance-club/library/refs/heads/main/Dandy's%20World/lib.lua"))()
local util = lib.Utility

if lib.Game.IsLobby then
    warn("please, don't execute this in lobby")
end

local Players = game:GetService("Players")
local player = Players.LocalPlayer

local LOOP_DELAY = 0.15
local ABOVE_OFFSET = Vector3.new(0, 5, 0)
local CHASE_IMAGE = "rbxassetid://18141936824"

local escaping = false

local function safe(f)
    local ok, res = pcall(f)
    if ok then return res end
    return nil
end

-- distance
local function dist(a, b)
    return safe(function()
        return util.GetDistanceBetweenObjects(a, b)
    end) or math.huge
end

-- dhetet chase, idk if this will do anything
local function isChased()
    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return false end

    local screen = gui:FindFirstChild("ScreenGui")
    if not screen then return false end

    local icon = screen:FindFirstChild("MonsterIcon")
    if not icon then return false end

    return icon.Image == CHASE_IMAGE
end

-- safe spottttttt
local function getSafeSpot()
    return workspace:FindFirstChild("Elevators")
        and workspace.Elevators:FindFirstChild("Elevator")
        and workspace.Elevators.Elevator:FindFirstChild("DandyStore")
        and workspace.Elevators.Elevator.DandyStore:FindFirstChild("Slot2")
end

local function goSafe()
    local spot = getSafeSpot()
    if spot then
        local pos = util.GetPosition(spot)
        if pos then
            util.LocalCharacter:PivotTo(CFrame.new(pos + Vector3.new(0,6,0)))
        end
    end
end

-- generator
local function getClosestGen()
    local gens = safe(function()
        return lib.Generators.GetAll()
    end)

    if not gens then return nil end

    local best, d = nil, math.huge

    for _, g in pairs(gens) do
        local available = safe(function()
            return lib.Generators.IsAvailable(g)
        end)

        local completed = safe(function()
            return lib.Generators.IsCompleted(g)
        end)

        if available and not completed then
            local dd = dist(util.LocalCharacter, g)
            if dd < d then
                best = g
                d = dd
            end
        end
    end

    return best
end

local function doGen(gen)
    local pos = util.GetPosition(gen)
    if pos then
        util.LocalCharacter:PivotTo(CFrame.new(pos + ABOVE_OFFSET))
    end

    local prompt = gen:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        fireproximityprompt(prompt)
    end
end

-- is panic
local function isPanic()
    local info = workspace:FindFirstChild("Info")
    if not info then return false end

    local hurry = info:FindFirstChild("HurryUp")
    local panic = info:FindFirstChild("Panic")

    return (hurry and hurry.Value) or (panic and panic.Value)
end

-- normal auto skillcheck
local function getSkillUI()
    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return end

    local screen = gui:FindFirstChild("ScreenGui")
    if not screen then return end

    local menu = screen:FindFirstChild("Menu")
    if not menu then return end

    return menu:FindFirstChild("SkillCheckFrame")
end

local function isInside(marker, area)
    local mPos = marker.AbsolutePosition.X
    local mSize = marker.AbsoluteSize.X

    local aPos = area.AbsolutePosition.X
    local aSize = area.AbsoluteSize.X

    return (mPos >= aPos) and (mPos + mSize <= aPos + aSize)
end

local function pressSpace()
    keypress(0x20)
    task.wait()
    keyrelease(0x20)
end

task.spawn(function()
    while task.wait() do
        local frame = getSkillUI()
        if not frame or not frame.Visible then continue end

        local marker = frame:FindFirstChild("Marker")
        local gold = frame:FindFirstChild("GoldArea") or frame:FindFirstChild("RequiredArea")

        if marker and gold then
            if isInside(marker, gold) then
                pressSpace()
                task.wait(0.08)
            end
        end
    end
end)

-- main loop haha
task.spawn(function()
    while task.wait(LOOP_DELAY) do
        if not workspace:FindFirstChild("CurrentRoom") then
            continue
        end

        if isChased() then
            escaping = true
            goSafe()
            continue
        end

        if escaping then
            escaping = false
            task.wait(0.5)
        end

        if isPanic() then
            goSafe()
            continue
        end

        local gen = getClosestGen()
        if gen then
            doGen(gen)
        end
    end
end)
